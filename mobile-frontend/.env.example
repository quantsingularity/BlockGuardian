# WalletConnect Configuration
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# App Configuration
EXPO_PUBLIC_APP_NAME=BlockGuardian
EXPO_PUBLIC_APP_URL=https://blockguardian.io
EXPO_PUBLIC_APP_ICON_URL=https://blockguardian.io/icon.png
EXPO_PUBLIC_DEEP_LINK_SCHEME=blockguardian

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Blockchain RPC URLs (optional - defaults to public endpoints)
EXPO_PUBLIC_ETH_RPC_URL=https://ethereum.publicnode.com
EXPO_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
EXPO_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
EXPO_PUBLIC_OPTIMISM_RPC_URL=https://mainnet.optimism.io
EXPO_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org

# Feature Flags
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false
